rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get current user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isVendor() {
      return request.auth != null && getUserRole() == 'vendor';
    }

    // --- LAPTOPS ---
    // Public read for laptops; only vendors/admins can create
    match /laptops/{laptopId} {
      allow read: if true;

      // Fix #3: Only vendors (or admins) can create laptop listings
      allow create: if isVendor() || isAdmin();

      // Only the owning vendor or admin can update/delete
      allow update, delete: if request.auth != null &&
        (resource.data.vendorId == request.auth.uid || isAdmin());
    }

    // --- USERS ---
    // Fix #4: Users can read/write their own profile BUT cannot self-escalate their role
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow create (registration) — role must be 'student' or 'vendor', never 'admin'
      allow create: if request.auth != null && request.auth.uid == userId &&
        request.resource.data.role in ['student', 'vendor'];

      // Allow update but block any role change (prevents client-side admin escalation)
      allow update: if request.auth != null && request.auth.uid == userId &&
        (!request.resource.data.keys().hasAny(['role']) ||
          request.resource.data.role == resource.data.role);
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      // Students can create orders when logged in
      allow create: if request.auth != null;

      // Students can read their own orders; vendors can read orders for their laptops; admins see all
      allow read: if request.auth != null &&
        (resource.data.studentId == request.auth.uid ||
         resource.data.vendorId == request.auth.uid ||
         isAdmin());

      // Vendors can update status of orders where they are the vendor; admins can update any
      allow update: if request.auth != null &&
        (resource.data.vendorId == request.auth.uid || isAdmin());
    }

    // --- CATCH-ALL: Admins can read/write everything ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}